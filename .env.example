# Zac Personal Assistant - Environment Configuration

# Voice Settings
VOICE_LANGUAGE=pt-br
VOICE_ENGINE=pyttsx3
VOICE_RATE=150
VOICE_VOLUME=1.0

# Browser Settings
BROWSER_TYPE=chromium
BROWSER_HEADLESS=false

# Database Settings
DATABASE_PATH=data/zac.db
LOG_LEVEL=INFO

# API Settings
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=false

# Google Sheets Settings
GOOGLE_SHEETS_CREDENTIALS=credentials.json
SPREADSHEET_ID=

# Scheduler Settings
SCHEDULER_CHECK_INTERVAL=60

# Logging Settings
LOG_FILE=logs/zac.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
